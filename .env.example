# Supabase (frontend)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# AVISO: a service_role key NUNCA deve ser usada no frontend.
# Mantenha apenas para scripts standalone que rodam em ambiente seguro.
VITE_SUPABASE_SERVICE_KEY=your-service-role-key

# Kommo CRM (frontend)
VITE_KOMMO_TOKEN=your-kommo-bearer-token
VITE_KOMMO_SUBDOMAIN=academicosoead

# Scripts Python (preencher_polo_sumaganhos.py, gerar_planilha_ganhos.py)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
KOMMO_TOKEN=your-kommo-bearer-token
KOMMO_SUBDOMAIN=academicosoead
